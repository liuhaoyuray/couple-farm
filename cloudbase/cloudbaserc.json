{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "envId": "couple-farm-d8gtiahu251a27c23",
  "functionRoot": "./functions",
  "functions": [
    {
      "name": "couple-tracker",
      "dir": "./functions/couple-tracker",
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "timeout": 30,
      "memorySize": 256,
      "description": "我们俩的小田地：单人体验、情侣记录、熟人村庄与日程提醒",
      "triggers": [
        {
          "name": "couple-reminders",
          "type": "timer",
          "config": "0 */5 * * * * *"
        }
      ]
    }
  ]
}
